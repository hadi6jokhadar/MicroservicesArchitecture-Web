{
  "compileOnSave": false,
  "compilerOptions": {
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2020", "dom"],
    "baseUrl": ".",
    "paths": {
      "@ihsan/core": ["libs/core/src/index.ts"],
      "@ihsan/shared": ["libs/shared/src/index.ts"],
      "@ihsan/shared/*": ["libs/shared/src/*"],
      "@ihsan/ui": ["libs/ui/src/index.ts"],
      "@ihsan/ui/*": ["libs/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
