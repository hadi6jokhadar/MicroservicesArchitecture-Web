{
  "name": "nasheed-admin",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/nasheed/admin/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/nasheed/admin",
        "browser": "apps/nasheed/admin/src/main.ts",
        "tsConfig": "apps/nasheed/admin/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "polyfills": ["zone.js"],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/nasheed/admin/public"
          }
        ],
        "styles": ["apps/nasheed/admin/src/styles.css"]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/nasheed/admin/src/environments/environment.ts",
              "with": "apps/nasheed/admin/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4300
      },
      "configurations": {
        "production": {
          "buildTarget": "nasheed-admin:build:production"
        },
        "development": {
          "buildTarget": "nasheed-admin:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "nasheed-admin:build",
        "staticFilePath": "dist/apps/nasheed/admin/browser",
        "spa": true
      }
    },
    "start-backend": {
      "executor": "nx:run-commands",
      "options": {
        "command": "start cmd /k node ..\\MicroservicesArchitecture\\src\\Apps\\Nasheed\\Nasheed.API\\run-development-instance.mjs"
      }
    }
  }
}
